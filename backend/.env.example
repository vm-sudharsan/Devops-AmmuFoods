# ============================================
# AMMUFOODS BACKEND ENVIRONMENT VARIABLES
# ============================================
# IMPORTANT: Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control!

# Server Configuration
PORT=5000
NODE_ENV=development

# Database
# Get your MongoDB connection string from MongoDB Atlas
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# JWT Authentication
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_minimum_32_characters_long

# Google OAuth
# Get from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id_here

# Email Configuration (Gmail SMTP)
# Get app password from: https://myaccount.google.com/apppasswords
SMTP_EMAIL=your_email@gmail.com
SMTP_APP_PASSWORD=your_16_character_app_password
ADMIN_EMAIL=admin@yourdomain.com

# Frontend URLs (for CORS)
FRONTEND_URL=https://your-production-domain.com
FRONTEND_DEV_URL=http://localhost:5173

# Cloudinary (for image uploads)
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Cookie Configuration (production)
COOKIE_DOMAIN=your-domain.com
SECURE_COOKIE=true

# ============================================
# SECURITY NOTES:
# 1. Use strong, unique passwords
# 2. Never share these credentials
# 3. Rotate secrets regularly
# 4. Use different values for dev/staging/prod
# ============================================
